# ── Flutter client (bundled in web build) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Vercel API (server-side only, set in Vercel Dashboard → Settings → Environment Variables) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-random-cron-secret
# Required: powers AI features for all users via /api/claude proxy
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: enables AI-powered daily digest (legacy)
OPENAI_API_KEY=your-openai-key
